---
import BaseLayout from '@/layouts/BaseLayout.astro'; import PostCard from '@/components/PostCard.astro'; import PayButton from '@/components/PayButton'; import PaymentReturn from '@/components/PaymentReturn.astro'; import { feedPosts } from '@/lib/data';
import { getEnv } from '@/lib/env';
const id = Astro.params.id!; const env = getEnv(Astro.locals); const [rendered] = await feedPosts(env.DB, { postId: id, userId: Astro.locals.user?.id, limit: 1 }); if (!rendered || (rendered.visibility === 'private' && Astro.locals.user?.id !== rendered.authorId)) return Astro.redirect('/404');
const params = Astro.url.searchParams; const isAuthor = Astro.locals.user?.id === rendered.authorId;
// Stripe sends the buyer back here; only the author (publish) / the payer (boost) should see the return state.
const returnState = isAuthor && params.get('paid') === '1' ? 'paid' : Astro.locals.user && params.get('boosted') === '1' ? 'boosted' : isAuthor && params.get('canceled') === '1' ? 'canceled' : null;
const canPublish = isAuthor && rendered.visibility === 'private' && rendered.postedOn === new Date().toISOString().slice(0, 10) && returnState !== 'paid';
const origin = (env.SITE_URL ?? Astro.url.origin).replace(/\/$/, '');
const og = `${origin}/api/og/${id}.png`;
---
<BaseLayout title={`${rendered.body.slice(0, 60)} — RETARDMAX`} description={`${rendered.body} — @${rendered.handle}`} image={og}><section class="space-y-5"><a href="/" class="text-sm font-black text-white/45 hover:text-white">← Back to the board</a>{returnState && <PaymentReturn state={returnState} postId={id} body={rendered.body} siteUrl={origin} />}<PostCard post={rendered} user={Astro.locals.user} />{canPublish && <div class="card space-y-4 border-flame/40 bg-flame/[0.06] p-6 text-center"><p class="eyebrow">Unlock the stage</p><p class="font-display text-4xl sm:text-5xl">GO PUBLIC.</p><p class="mx-auto max-w-sm text-sm font-bold text-white/60">A dollar supports the site, gates the bots, and drops your move straight onto the board.</p><PayButton client:load postId={id} /></div>}</section></BaseLayout>
