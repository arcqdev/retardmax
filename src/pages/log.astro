---
import BaseLayout from '@/layouts/BaseLayout.astro'; import PostCard from '@/components/PostCard.astro'; import PayButton from '@/components/PayButton'; import { feedPosts } from '@/lib/data';
import { getEnv } from '@/lib/env';
if (!Astro.locals.user) return Astro.redirect('/api/auth/login?next=/log');
const own = await feedPosts(getEnv(Astro.locals).DB, { authorId: Astro.locals.user.id, userId: Astro.locals.user.id, limit: 200 }); own.sort((a, b) => b.createdAt.getTime() - a.createdAt.getTime()); const today = new Date().toISOString().slice(0, 10);
---
<BaseLayout title="My Log — RETARDMAX"><section class="space-y-6"><div><p class="eyebrow">Your receipts</p><h1 class="font-display text-6xl">MY LOG.</h1><p class="font-bold text-white/50">🔥 {Astro.locals.user.streakCount} day streak · {own.length} {own.length === 1 ? 'move' : 'moves'} logged</p></div>{own.length ? own.map((post) => <div class="space-y-3"><PostCard post={post} user={Astro.locals.user} />{post.visibility === 'private' && post.postedOn === today && <div class="sm:mx-auto sm:max-w-md"><PayButton client:load postId={post.id} /></div>}</div>) : <div class="card p-8 text-center"><p class="font-display text-3xl">NO RECEIPTS YET.</p><p class="mx-auto mt-2 max-w-xs font-bold text-white/50">The log starts the day you do something worth logging.</p><a class="btn-flame mt-5" href="/">Log today’s move</a></div>}</section></BaseLayout>
