---
import BaseLayout from '@/layouts/BaseLayout.astro'; import { userGroups } from '@/lib/data';
import { getEnv } from '@/lib/env';
if (!Astro.locals.user) return Astro.redirect('/api/auth/login?next=/g'); const groups = await userGroups(getEnv(Astro.locals).DB, Astro.locals.user.id);
---
<BaseLayout title="Groups — RETARDMAX"><section class="space-y-6"><div><p class="eyebrow">Your crew</p><h1 class="font-display text-6xl">GROUPS.</h1></div><div class="grid gap-3">{groups.map((g) => <a class="card flex items-center justify-between p-5 hover:border-flame/50" href={`/g/${g.id}`}><span class="font-display text-3xl">{g.name}</span><span class="text-sm font-black text-flame">OPEN →</span></a>)}{!groups.length && <div class="card p-8 text-center"><p class="font-display text-2xl">NO CREW YET.</p><p class="mt-1 font-bold text-white/50">Start one below, or paste an invite code. Moves hit different when your friends are watching.</p></div>}</div><form action="/api/groups" method="POST" class="card space-y-3 p-5"><p class="eyebrow">Start a group</p><input required maxlength="60" name="name" placeholder="The 6am psychos" class="field" /><button class="btn-flame">Create group</button></form><form action="/api/groups/join" method="POST" class="card space-y-3 p-5"><p class="eyebrow">Join with an invite</p><input required maxlength="8" name="code" placeholder="8-character code" class="field uppercase" /><button class="btn-quiet">Join group</button></form></section></BaseLayout>
