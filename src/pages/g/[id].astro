---
import BaseLayout from '@/layouts/BaseLayout.astro'; import PostCard from '@/components/PostCard.astro'; import { eq } from 'drizzle-orm'; import { db } from '@/lib/db/db'; import { groupMembers, users } from '@/lib/db/schema'; import { feedPosts, groupForUser } from '@/lib/data';
import { getEnv } from '@/lib/env';
if (!Astro.locals.user) return Astro.redirect('/api/auth/login'); const id = Astro.params.id!; const env = getEnv(Astro.locals); const group = await groupForUser(env.DB, id, Astro.locals.user.id); if (!group) return Astro.redirect('/g'); const members = await db(env.DB).select({ id: users.id, handle: users.handle, avatarUrl: users.avatarUrl }).from(groupMembers).innerJoin(users, eq(groupMembers.userId, users.id)).where(eq(groupMembers.groupId, id)).all(); const today = await feedPosts(env.DB, { date: new Date().toISOString().slice(0, 10), groupId: id, userId: Astro.locals.user.id, limit: 10 }); const all = await feedPosts(env.DB, { groupId: id, userId: Astro.locals.user.id, limit: 100 }); all.sort((a, b) => b.wCount - a.wCount || a.createdAt.getTime() - b.createdAt.getTime());
---
<BaseLayout title={`${group.name} — RETARDMAX`}><section class="space-y-6"><div class="card space-y-3 border-flame/30 p-5"><p class="eyebrow">Crew board</p><h1 class="font-display text-6xl">{group.name}</h1><p class="text-sm text-white/50">Invite link: <a class="break-all font-black text-flame hover:underline" href={`/g/join/${group.inviteCode}`}>{`${Astro.url.origin}/g/join/${group.inviteCode}`}</a></p></div><div><p class="eyebrow">Today</p><h2 class="font-display text-4xl">GROUP TOP 10</h2></div>{today.length ? today.map((post, i) => <PostCard post={post} user={Astro.locals.user} rank={i + 1} stat={{ value: post.dailyScore, label: 'PTS' }} />) : <div class="card p-8 text-center"><p class="font-display text-2xl">NOTHING TODAY.</p><p class="mt-1 font-bold text-white/50">Log a move and share it to this crew to start the board.</p><a class="btn-flame mt-5" href="/">Log today’s move</a></div>}<div><p class="eyebrow">Trophy case</p><h2 class="font-display text-4xl">ALL-TIME</h2></div>{all.length ? all.map((post, i) => <PostCard post={post} user={Astro.locals.user} rank={i + 1} />) : <div class="card p-5 text-center font-bold text-white/50">No history yet. Somebody has to go first.</div>}<div class="card space-y-3 p-5"><p class="eyebrow">Members · {members.length}</p>{members.map((member) => <div class="flex items-center justify-between"><a href={`/u/${member.handle}`} class="font-bold">@{member.handle}</a>{group.creatorUserId === Astro.locals.user!.id && member.id !== Astro.locals.user!.id && <form action={`/api/groups/${id}/kick`} method="POST"><input type="hidden" name="user_id" value={member.id} /><button class="text-xs font-black uppercase text-flame">Kick</button></form>}</div>)}</div></section></BaseLayout>
