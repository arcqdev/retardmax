---
import BaseLayout from '@/layouts/BaseLayout.astro'; import PostCard from '@/components/PostCard.astro'; import { allTimeTop } from '@/lib/data';
import { getEnv } from '@/lib/env';
const posts = await allTimeTop(getEnv(Astro.locals).DB, Astro.locals.user?.id);
---
<BaseLayout title="All-Time Legends — RETARDMAX"><section class="space-y-6"><div><p class="eyebrow">The trophy case</p><h1 class="font-display text-6xl leading-[0.9] sm:text-7xl">ALL-TIME<br /><span class="text-flame">LEGENDS.</span></h1><p class="mt-3 font-bold text-white/50">Ranked on lifetime Ws. Boosts stay out of the history books.</p></div>{posts.length ? posts.map((post, i) => <PostCard post={post} user={Astro.locals.user} rank={i + 1} />) : <div class="card p-8 text-center"><p class="font-display text-2xl">NO LEGENDS YET.</p><p class="mt-1 font-bold text-white/50">History’s wide open. Go take it.</p></div>}</section></BaseLayout>
