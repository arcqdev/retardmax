---
import BaseLayout from '@/layouts/BaseLayout.astro'; import PostCard from '@/components/PostCard.astro'; import { allTimeTop } from '@/lib/data';
import { getEnv } from '@/lib/env';
const posts = await allTimeTop(getEnv(Astro.locals).DB, Astro.locals.user?.id);
---
<BaseLayout title="All-Time Legends — RETARDMAX"><section class="space-y-6"><div><p class="eyebrow">The trophy case</p><h1 class="font-display text-6xl">ALL-TIME<br /><span class="text-flame">LEGENDS.</span></h1><p class="mt-2 font-bold text-white/50">Lifetime Ws only. Boosts stay out of the history books.</p></div>{posts.length ? posts.map((post, i) => <PostCard post={post} user={Astro.locals.user} rank={i + 1} />) : <div class="card p-8 text-center text-lg font-bold text-white/50">No legends yet. History’s wide open.</div>}</section></BaseLayout>
