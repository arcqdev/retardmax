---
import BaseLayout from '@/layouts/BaseLayout.astro'; import PostCard from '@/components/PostCard.astro'; import { eq } from 'drizzle-orm'; import { db } from '@/lib/db/db'; import { users } from '@/lib/db/schema'; import { feedPosts } from '@/lib/data';
import { getEnv } from '@/lib/env';
const env = getEnv(Astro.locals); const handle = Astro.params.handle!; const found = await db(env.DB).select().from(users).where(eq(users.handle, handle)).get(); if (!found) return Astro.redirect('/404'); const userPosts = await feedPosts(env.DB, { publicOnly: true, authorId: found.id, userId: Astro.locals.user?.id, limit: 100 });
---
<BaseLayout title={`@${found.handle} — RETARDMAX`}><section class="space-y-6"><div class="card flex items-center gap-4 p-5"><img src={found.avatarUrl ?? `https://api.dicebear.com/9.x/initials/svg?seed=${found.handle}`} alt="" class="h-20 w-20 rounded-full border-2 border-flame" /><div><p class="eyebrow">Public profile</p><h1 class="font-display text-5xl">@{found.handle}</h1><p class="font-bold text-white/55">🔥 {found.streakCount} day streak {found.xHandle && <>· <a class="text-flame" href={`https://x.com/${found.xHandle.replace(/^@/, '')}`}>X @{found.xHandle.replace(/^@/, '')}</a></>}</p></div></div><h2 class="font-display text-4xl">PUBLIC MOVES</h2>{userPosts.length ? userPosts.map((post) => <PostCard post={post} user={Astro.locals.user} />) : <div class="card p-8 text-center"><p class="font-display text-2xl">NOTHING ON THE BOARD.</p><p class="mt-1 font-bold text-white/50">@{found.handle} hasn’t put a move up in public yet.</p></div>}</section></BaseLayout>
