---
import PostActions from './PostActions';
import { relTime } from '@/lib/utils';
const { post, user, rank, stat } = Astro.props;
const isOwner = user?.id === post.authorId;
const isPublic = post.visibility === 'public';
const medal = rank === 1 ? 'gold' : rank === 2 ? 'silver' : rank === 3 ? 'bronze' : null;
const rankColor = medal === 'gold' ? 'text-gold' : medal === 'silver' ? 'text-silver' : medal === 'bronze' ? 'text-bronze' : 'text-white/25';
const stamp = post.createdAt.toISOString().replace('T', ' ').slice(0, 16) + ' UTC';
---
<article class={`card overflow-hidden p-5 sm:p-6 ${medal ? `medal medal-${medal}` : ''}`}>
  <div class="flex gap-4">
    {rank && (
      <div class="flex w-10 shrink-0 flex-col items-center pt-0.5 sm:w-14">
        <span class={`font-display text-4xl leading-none tabular-nums sm:text-6xl ${rankColor}`}>{rank}</span>
        {medal && <span class="mt-1 text-[9px] font-black uppercase tracking-[0.18em] text-white/40">{medal}</span>}
        {stat && <span class="mt-2 text-center font-display text-sm leading-none tabular-nums text-white/40">{stat.value}<span class="mt-0.5 block text-[9px] tracking-[0.14em] text-white/25">{stat.label}</span></span>}
      </div>
    )}
    <div class="min-w-0 flex-1">
      <div class="flex items-start gap-3">
        <img src={post.avatarUrl ?? `https://api.dicebear.com/9.x/initials/svg?seed=${post.handle}`} alt="" class="h-10 w-10 shrink-0 rounded-full border border-white/15" />
        <div class="min-w-0 flex-1">
          <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
            <a href={`/u/${post.handle}`} class="font-black hover:text-flame">@{post.handle}</a>
            <span class="text-xs font-bold text-white/45" title={`${post.streakCount}-day streak`}>🔥 {post.streakCount}</span>
            {!isPublic && <span class="rounded bg-white/10 px-1.5 py-0.5 text-[10px] font-black uppercase tracking-wide text-white/45">private</span>}
          </div>
          <p class="text-xs text-white/35"><time datetime={post.createdAt.toISOString()} title={stamp}>{relTime(post.createdAt)}</time></p>
        </div>
        {post.xHandle && <a href={`https://x.com/${post.xHandle.replace(/^@/, '')}`} target="_blank" rel="noreferrer" class="shrink-0 text-xs font-bold text-white/45 hover:text-white">X @{post.xHandle.replace(/^@/, '')}</a>}
      </div>
      <a href={`/p/${post.id}`} class="mt-3 block whitespace-pre-wrap text-xl font-bold leading-snug tracking-tight hover:text-white/80 sm:text-2xl">{post.body}</a>
      {post.imageKey && <img src={`/media/${post.imageKey}`} alt="" class="mt-4 max-h-96 w-full rounded-xl border border-white/10 object-cover" />}
      <div class="mt-5 border-t border-white/5 pt-4">
        {isPublic
          ? <PostActions client:load postId={post.id} initialVotes={post.wCount} initialBoosts={post.boostCount} voted={post.voted} signedIn={Boolean(user)} isOwner={isOwner} body={post.body} />
          : <p class="text-xs font-bold text-white/35">Private — only you can see this. Ws, boosts and the board start at $1.</p>}
      </div>
    </div>
  </div>
</article>
