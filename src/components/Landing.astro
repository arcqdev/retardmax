---
// Logged-out hero. Zero JS: reveals are CSS scroll-driven (view()/scroll()) and degrade to plain static type.
const manifesto = [
  { line: 'POST THE THING.', note: 'One move a day. No drafts, no committee, no second post.' },
  { line: 'PAY $1. SHIP IT PUBLIC.', note: 'A dollar gates the bots and puts your receipt on the wall.' },
  { line: 'COLLECT Ws.', note: 'Ws, boosts, streaks. Top 10 daily. Legends all-time.' },
  { line: 'THE IDIOT IS THE ENEMY OF THE RETARD.', note: 'Idiots deliberate. You just went and did it.' },
];
const chant = 'NOTHING MOVES IF NOTHING MOVES. · WHOOPSIE YOUR WAY THROUGH LIFE. · MUCK AROUND AND FIND OUT. · SUCK THE JUICE FROM EVERY CORNER OF LIFE. · ';
---
<div class="space-y-8 lg:-mx-12 xl:-mx-24">
  <div class="relative overflow-hidden rounded-2xl border border-flame/30 bg-flame/[0.06] p-6 shadow-2xl shadow-black/40 sm:p-10">
    <p class="eyebrow">Daily · one bold move · public board</p>
    <h1 class="mt-3 font-display text-[3.5rem] leading-[0.88] sm:text-8xl xl:text-9xl">
      <span class="scrub-line block">MAKE ONE</span>
      <span class="scrub-line block">BOLD MOVE.</span>
      <span class="scrub-line block text-flame">PROVE IT.</span>
    </h1>
    <p class="mt-6 max-w-lg text-lg font-bold text-white/60">All quiet on the frontal lobe. Log the boldest thing you did today, pay a dollar to make it public, and let the board decide.</p>
    <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center">
      <a class="btn-flame px-6 py-3 text-base" href="/api/auth/login">Sign in with Google</a>
      <span class="text-sm font-bold text-white/45">Two clicks. Then post today’s move.</span>
    </div>
  </div>

  <div class="bleed overflow-hidden border-y border-white/10 py-3" aria-hidden="true">
    <p class="ticker-track w-max whitespace-nowrap font-display text-2xl text-white/15 sm:text-3xl">{chant}{chant}{chant}</p>
  </div>

  <div class="space-y-12 sm:space-y-20">
    {manifesto.map((item) => (
      <div class="scrub-block">
        <p class="font-display text-4xl leading-[0.95] sm:text-6xl xl:text-7xl">{item.line}</p>
        <p class="mt-3 max-w-md text-base font-bold text-white/50">{item.note}</p>
      </div>
    ))}
    <div class="scrub-block">
      <p class="font-display text-4xl leading-[0.95] text-flame sm:text-6xl xl:text-7xl">NOTHING MOVES<br />IF NOTHING MOVES.</p>
      <a class="btn-flame mt-6 px-6 py-3 text-base" href="/api/auth/login">Sign in with Google</a>
      <p class="mt-3 text-sm font-bold text-white/40">Short Bus Conquistadors only. Zero due diligence, max conviction.</p>
    </div>
  </div>
</div>
